<% layout("/layouts/boilerplate") %>
<div id="filters">
    <button class="scroll-btn left-btn">&#10094;</button>
    <div class="filters-scroll">
        <div class="filter">
            <a href="/listings">
                <div><i class="fa-solid fa-fire"></i></div>
                <p>Trending</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=Rooms">
                <div><i class="fa-solid fa-bed"></i></div>
                <p>Rooms</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=Iconic Cities">
                <div><i class="fa-solid fa-mountain-city"></i></div>
                <p>Iconic Cities</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=Beach" >
                <div><i class="fa-solid fa-umbrella-beach"></i></div>
                <p>Beach</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=Mountains" >
                <div><i class="fa-solid fa-mountain"></i></div>
                <p>Mountains</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=Castles" >
                <div><i class="fa-brands fa-fort-awesome"></i></div>
                <p>Castles</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=Amazing Pools" >
                <div><i class="fa-solid fa-person-swimming"></i></div>
                <p>Amazing Pools</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=Camping" >
                <div><i class="fa-solid fa-campground"></i></div>
                <p>Camping</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=Farms" >
                <div><i class="fa-solid fa-cat"></i></div>
                <p>Farms</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=Arctic" >
                <div><i class="fa-regular fa-snowflake"></i></div>
                <p>Arctic</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=Cruise" >
                <div><i class="fa-solid fa-ship"></i></div>
                <p>Cruise</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=Heritage" >
                <div><i class="fa-solid fa-landmark"></i></div>
                <p>Heritage</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=Theme Parks" >
                <div><i class="fa-solid fa-masks-theater"></i></div>
                <p>Theme Parks</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=Treehouses" >
                <div><i class="fa-solid fa-tree"></i></div>
                <p>Treehouses</p>
            </a>
        </div>
        <div class="filter">
            <a href="/listings?category=Desert Retreats" >
                <div><i class="fa-solid fa-mountain-sun"></i></div>
                <p>Desert Retreats</p>
            </a>
        </div>
    </div>
    <button class="scroll-btn right-btn">&#10095;</button>

    <div class="tax-toggle">
        <div class="form-check form-switch form-check-reverse">
            <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
            <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
        </div>
    </div>
</div>

<% if(search) { %>
    <div class="mt-3">
        <h5>Showing results for <span class="text-primary">"<%= search %>"</span></h5>
    </div>
<% } %>

<% if(search && allListings.length === 0) { %>
    <h4 class="text-center mt-5">
        No listings found for "<%= search %>" 😢
    </h4>
<% } else { %>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <% for(listing of allListings) { %>
            <a href="/listings/<%=listing._id%>" class="listing-link">
                <div class="card col listing-card">
                    <img class="card-img-top" src="<%= listing.image.url %>" alt="listing_image" style="height: 20rem;">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%= listing.title %></b> <br>
                            &#8377;<%= listing.price.toLocaleString("en-IN") %>/night
                            <i class="tax-info">&nbsp;&nbsp;+18% GST included</i>
                        </p>
                    </div>
                </div>
            </a>
        <% } %> 
    </div>
<% } %>